{
  "name": "node-radarr-redownloader",
  "version": "1.0.0",
  "private": true,
  "description": "Delete and re-add Radarr movies in descending size order with search enabled.",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "node --env-file=.env index.js",
    "build:current": "pkg . --targets host --out-path dist",
    "build:all": "pkg . --targets node18-win-x64,node18-linux-x64,node18-macos-x64,node18-macos-arm64 --out-path dist"
  },
  "engines": {
    "node": ">=18"
  },
  "pkg": {
    "scripts": [
      "index.js",
      "src/**/*.js"
    ],
    "assets": [
      ".env.example",
      "README.md"
    ],
    "outputPath": "dist"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
